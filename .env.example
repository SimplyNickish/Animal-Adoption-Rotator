# ═══════════════════════════════════════════════════════════════
# Animal Adoption Rotator — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# Variables prefixed with NEXT_PUBLIC_ are visible to the browser.
# All others are server-only (never exposed to users).

# ── Supabase (Required) ──────────────────────────────────────
# Your Supabase project URL and anonymous key (from Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# Service Role Key — SERVER ONLY. Used for secure license key validation.
# Never prefix with NEXT_PUBLIC_ or it will be exposed to browsers.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# ── Widget URL (Required) ────────────────────────────────────
# The base URL where this app is hosted (no trailing slash)
NEXT_PUBLIC_WIDGET_BASE_URL="https://app.simplynickish.com"

# ── Fourthwall Master Key (Required) ─────────────────────────
# The shared passphrase given to your Fourthwall subscribers.
# This is validated SERVER-SIDE only — never visible to browsers.
FOURTHWALL_MASTER_KEY="YOUR-SECRET-MEMBER-KEY-HERE"

# ── RescueGroups API (Optional) ──────────────────────────────
# Get a free key at: https://rescuegroups.org/services/adoptable-pet-data-api/
# Without this, the US animal source won't work (UK + Australia still will).
RESCUE_GROUPS_API_KEY=""

# ── Twitch OAuth (Optional — for chat bot login) ─────────────
# Register at: https://dev.twitch.tv/console/apps
# Set the OAuth Redirect URL to your dashboard URL (e.g. https://app.simplynickish.com/dashboard)
NEXT_PUBLIC_TWITCH_CLIENT_ID=""
NEXT_PUBLIC_DASHBOARD_URL="https://app.simplynickish.com/dashboard"
